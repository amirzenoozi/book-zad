{
  "name": "book-zad",
  "description": "A smarter bookmark manager: score, search, and de-clutter your bookmarks, with on-device similarity nudges while you browse.",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "author": "Amir Douzandeh (https://github.com/amirzenoozi)",
  "license": "CC-BY-NC-4.0",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:edge": "wxt zip -b edge",
    "package": "wxt zip && wxt zip -b firefox && wxt zip -b edge",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:icons": "node scripts/gen-icons.mjs",
    "submit:chrome": "wxt submit --chrome-zip .output/*-chrome.zip",
    "submit:firefox": "wxt submit --firefox-zip .output/*-firefox.zip --firefox-sources-zip .output/*-sources.zip",
    "submit:edge": "wxt submit --edge-zip .output/*-edge.zip",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wxt": "^0.20.26"
  },
  "dependencies": {
    "@webext-core/messaging": "^3.0.2"
  }
}
